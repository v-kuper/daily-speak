{
  "name": "daily-speaking-practice",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "cd backend && go run ./cmd/api",
    "backend:test": "cd backend && go test ./...",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:smoke": "node scripts/smoke-api.mjs",
    "test:browser-media": "node --test scripts/browser-media.test.mjs",
    "test:docker-lan": "node --test scripts/docker-lan.test.mjs",
    "test:lan-https-proxy": "node --test scripts/lan-https-proxy.test.mjs",
    "build:api-docs": "node scripts/build-api-docs.mjs",
    "test:api-docs": "npm run build:api-docs && node --test scripts/api-docs.test.mjs",
    "test:ci": "node --test scripts/ci-workflows.test.mjs",
    "quality": "npm run typecheck && npm run lint && npm run backend:test && npm run test:browser-media && npm run test:docker-lan && npm run test:lan-https-proxy && npm run test:api-docs && npm run test:ci",
    "docker:app": "docker compose up --build -d app postgres",
    "docker:lan": "node scripts/docker-lan.mjs",
    "docker:build": "docker compose build app",
    "docker:logs": "docker compose logs -f app",
    "docker:stop": "docker compose down",
    "setup:whisper": "bash scripts/setup-whisper-openai-local.sh",
    "check:whisper": "bash scripts/check-whisper-local.sh"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.5.1",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.2.0",
    "typescript": "^5.7.2"
  }
}
